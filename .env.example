# BountyPilot Environment Variables
# Replit automatically provides DATABASE_URL and PORT
# You only need to set JWT_SECRET and QWEN_API_KEY

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# AI API Key (Alibaba Cloud Qwen)
QWEN_API_KEY=your-qwen-api-key

# Qwen Model Configuration
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus-2025-07-28
QWEN_BRIEF_MODEL=qwen-turbo

# Novus AI (optional — alternative to Qwen)
NOVUS_API_KEY=your-novus-api-key
NOVUS_BASE_URL=https://novus-api.pendo.io/mcp

# Dextopus Crypto Payment (optional)
DEXTOPUS_API_KEY=your-dextopus-api-key
DEXTOPUS_WEBHOOK_SECRET=your-webhook-secret
TREASURY_WALLET_ADDRESS=0x-your-treasury-wallet
