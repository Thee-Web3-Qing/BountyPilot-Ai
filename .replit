modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0", "stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 18933
externalPort = 80

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
QWEN_BASE_URL = "https://token-plan.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1"
QWEN_MODEL = "qwen3.6-flash"
TREASURY_WALLET_ADDRESS = "0x49B474B5d420851cE68e024Eb2AF77fEDB8e898C"
EMAIL_PROVIDER = "resend"
FROM_EMAIL = "noreply@bountypilot.xyz"
VITE_PRIVY_APP_ID = "cmqjb2mgv00dz0cjy1zniz7pq"
RAMPHUB_WALLET_ADDRESS = "0x49B474B5d420851cE68e024Eb2AF77fEDB8e898C"
